{
  "app_name": "Bibliogon",
  "app_slug": "bibliogon",
  "container_name": "bibliogon",
  "image_name": "bibliogon",
  "compose_project": "bibliogon",
  "compose_file": "docker-compose.prod.yml",
  "default_port": 7880,
  "env_port_key": "BIBLIOGON_PORT",
  "health_check_path": "/api/health",
  "health_check_key": "status",
  "health_check_value": "ok",
  "browser_path": "/",
  "icon_path": "frontend/public/icon-192.png",
  "tray_icon_path": "frontend/public/icon-192.png",
  "config_dir": "~/.config/bibliogon",
  "locale": "auto",
  "single_instance": true,
  "log_level": "INFO",
  "log_max_size": 1000000,
  "log_backup_count": 2,
  "repo_url": "https://github.com/astrapi69/bibliogon",
  "releases_url": "https://github.com/astrapi69/bibliogon/releases/latest",
  "docs_url": "https://github.com/astrapi69/bibliogon/blob/main/docs/help/en/install/docker-desktop.md",
  "update_check_enabled": true,
  "app_version": "0.58.0"
}
