ai:
  enabled: false
  provider: lmstudio
  api_key: ''
  base_url: http://localhost:1234/v1
  max_tokens: 2048
  model: ''
  temperature: 0.7
  bulk:
    # INTERNAL: per-batch caps for bulk AI operations. No Settings UI;
    # power users raise via YAML when their AI provider + configured
    # rate-limit comfortably absorb larger batches.
    # - max_ai_fill: cap on /articles|books/bulk-ai-fill (one LLM call
    #   per item per selected field-class). Conservative default of 50
    #   keeps a single run bounded.
    # - max_ai_template: cap on /articles|books/bulk-ai-template
    #   export+import (no LLM calls; ZIP packing only). Same default
    #   for UX consistency with the AI-fill cap.
    max_ai_fill: 50
    max_ai_template: 50
editor:
  autosave_debounce_ms: 800
  draft_save_debounce_ms: 2000
  draft_max_age_days: 30
  ai_context_chars: 2000
app:
  default_language: de
  delete_permanently: false
  description: Open-source book authoring platform
  name: Bibliogon
  supported_languages:
  - de
  - en
  - es
  - fr
  - el
  - pt
  - tr
  - ja
  trash_auto_delete_days: 90
  trash_auto_delete_enabled: true
  # Advanced: allow importing/saving books without an author. Default
  # off — the import wizard hides the "defer author" option and the
  # API rejects POST/PATCH that would clear the author column. Useful
  # for converting source documents to audiobooks where author info
  # is genuinely absent.
  allow_books_without_author: false
  # Defense-in-depth body-size cap enforced by
  # BodySizeLimitMiddleware. Applies to every POST / PUT / PATCH
  # request. Editing requires a server restart.
  max_upload_mb: 500
  version: 0.11.0
author:
  name: ''
  pen_names: []
plugins:
  config_dir: config/plugins
  disabled: []
  enabled:
  - export
  - help
  - getstarted
  - ms-tools
  - audiobook
  - kdp
  - translation
  - kinderbuch
  - grammar
  - git-sync
  - medium-import
  - comics
  - story-bible
  entry_point_group: bibliogon.plugins
ui:
  logo: assets/logo.svg
  subtitle: ''
  theme: warm-literary
  title: Bibliogon
  picture_book:
    # Workspace default for the picture-book / comic-book PDF export
    # controls (PdfExportControls). Authors can still override per
    # export in the inline controls; the Settings UI value sets the
    # initial pick when the export controls mount.
    # Allowed values: "8.5x8.5", "8x10", "8.5x11", "11x8.5", "10x8".
    pdf_default_format: "8.5x8.5"
    # Workspace default for the bleed + crop-marks checkbox alongside
    # the format dropdown. When true, the export controls mount with
    # bleed pre-enabled (3 mm bleed + crop marks for print-shop
    # submission). Per-export override stays available inline.
    pdf_default_bleed_marks: false
kdp:
  # Workspace default for the KDP Publishing Wizard pricing step.
  # The canonical pricing row (page-count anchor + summary
  # display) uses this region instead of the hardcoded "US"
  # fallback. User picks per-region prices within the wizard as
  # before; the default just changes which row is canonical.
  # Allowed values match KDP_REGIONS in pricing.ts:
  # "US", "EU", "UK", "JP", "IN".
  default_marketplace: "US"
behavior:
  # Power-user mode: when true, non-destructive AppDialog.confirm()
  # calls auto-resolve to "OK" without rendering. Destructive
  # confirmations (permanent-delete, danger-zone, type-to-confirm)
  # ALWAYS render regardless of this flag — they carry data-loss
  # risk and the safety prompt is load-bearing.
  skip_non_destructive_confirmations: false
features:
  # Project-level feature flags. Edit via this YAML, not via the
  # Settings UI.
  #
  # white_label:
  #   When true, the Settings > Erweitert tab is visible (carries
  #   SSH-key + white-label app customisation surfaces). When false
  #   (the default), the tab is hidden — power-user features stay
  #   accessible via direct YAML editing but don't clutter the
  #   sidebar for the typical author user.
  white_label: false
donations:
  # Project-level config: edit via this YAML, not via the Settings UI.
  # Flip `enabled: false` to hide all three donation visibility levels
  # (S-01 Settings section, S-02 onboarding dialog, S-03 90-day banner).
  # Set `landing_page_url` to a single URL to route every button there
  # instead of showing the per-channel list; leave null for the list.
  enabled: true
  landing_page_url: null
  channels:
    - name: Liberapay
      url: https://liberapay.com/astrapi69/donate
      icon: liberapay
      recommended: true
      description_key: ui.donations.channels.liberapay_desc
    - name: GitHub Sponsors
      url: https://github.com/sponsors/astrapi69
      icon: github
      description_key: ui.donations.channels.github_desc
    - name: Ko-fi
      url: https://ko-fi.com/astrapi69
      icon: kofi
      description_key: ui.donations.channels.kofi_desc
    - name: PayPal
      url: https://www.paypal.com/donate/?cmd=_s-xclick&hosted_button_id=MJ7V43GU2H386
      icon: paypal
      description_key: ui.donations.channels.paypal_desc
