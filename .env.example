# Bibliogon Production Environment Variables
# Copy to .env and adjust values for your deployment

# Port on which the app is accessible (default: 8080)
BIBLIOGON_PORT=7880

# Debug mode - set to false in production
# Disables: /api/test/reset endpoint, API docs (/api/docs)
BIBLIOGON_DEBUG=false

# CORS origins - comma-separated list of allowed frontend URLs
# In production with Docker, the frontend proxies via nginx, so localhost is fine
BIBLIOGON_CORS_ORIGINS=http://localhost:7880

# Secret key for premium plugin license validation
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BIBLIOGON_SECRET_KEY=change-me-to-a-random-secret

# Database path (SQLite) - should point to a persistent volume
# Only needed if not using the default Docker volume mount
# BIBLIOGON_DB_PATH=/app/data/bibliogon.db

# Full database URL (overrides BIBLIOGON_DB_PATH if set)
# For PostgreSQL: postgresql://user:password@host:5432/bibliogon
# DATABASE_URL=sqlite:////app/data/bibliogon.db
